rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper: is the request from a signed-in user? ──────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    // ── Helper: does this user belong to the couple? ───────────────────────
    function isCouplePartner(coupleDoc) {
      return request.auth.uid == coupleDoc.data.user1
          || request.auth.uid == coupleDoc.data.user2;
    }

    // ── Helper: is this user a partner of the couple that owns an event? ──
    function isEventPartner(coupleId) {
      return exists(/databases/$(database)/documents/couples/$(coupleId))
          && isCouplePartner(get(/databases/$(database)/documents/couples/$(coupleId)));
    }

    // ── Couples ────────────────────────────────────────────────────────────
    // Any signed-in user can read couple documents.
    // This is intentional: the invite-code join flow (joinCouple in
    // firestore.ts) queries the couples collection by inviteCode BEFORE the
    // joining user is recorded as user2.  Restricting reads to existing
    // partners would make that query silently return no results and break
    // the pairing flow.
    match /couples/{coupleId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
                    && (request.resource.data.user1 == request.auth.uid
                        || request.resource.data.user2 == request.auth.uid);

      // Allow existing partners to update, OR allow a new user to join a
      // pending couple by setting themselves as user2.  Without the second
      // clause, user2's UID isn't in the existing document yet, so the
      // isCouplePartner check fails and the join is silently denied.
      // The invite code itself is validated client-side in joinCouple().
      allow update: if isSignedIn()
                    && (isCouplePartner(resource)
                        || (resource.data.status == 'pending'
                            && resource.data.user2 == null
                            && request.resource.data.user2 == request.auth.uid
                            && request.resource.data.user1 == resource.data.user1));

      allow delete: if isSignedIn()
                    && isCouplePartner(resource);
    }

    // ── Events ─────────────────────────────────────────────────────────────
    // Both partners of a couple can CRUD events that belong to their couple.
    // Solo users (not yet paired) use coupleId == their own uid.
    match /events/{eventId} {
      allow read: if isSignedIn()
                  && (resource.data.coupleId == request.auth.uid
                      || isEventPartner(resource.data.coupleId));

      allow create: if isSignedIn()
                    && request.resource.data.createdBy == request.auth.uid
                    && (request.resource.data.coupleId == request.auth.uid
                        || isEventPartner(request.resource.data.coupleId));

      allow update: if isSignedIn()
                    && (resource.data.coupleId == request.auth.uid
                        || isEventPartner(resource.data.coupleId));

      allow delete: if isSignedIn()
                    && (resource.data.coupleId == request.auth.uid
                        || isEventPartner(resource.data.coupleId));
    }

    // ── User profiles ──────────────────────────────────────────────────────
    // Each user can read/write only their own profile document.
    match /users/{userId} {
      allow read, write: if isSignedIn()
                         && request.auth.uid == userId;
    }

    // ── Invites / pairing codes ────────────────────────────────────────────
    // Anyone signed in can read an invite (to look up a partner code).
    // Only the creator can write it.
    match /invites/{inviteId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isSignedIn()
                            && resource.data.createdBy == request.auth.uid;
    }

    // ── Event history (audit log) ──────────────────────────────────────────
    // Both partners can read history entries for their couple.
    // Solo users can read/write their own history (coupleId == uid).
    // Entries are immutable once created.
    match /eventHistory/{historyId} {
      allow read: if isSignedIn()
                  && (resource.data.coupleId == request.auth.uid
                      || isEventPartner(resource.data.coupleId));

      allow create: if isSignedIn()
                    && request.resource.data.changedBy == request.auth.uid
                    && (request.resource.data.coupleId == request.auth.uid
                        || isEventPartner(request.resource.data.coupleId));

      // Allow updating coupleId during migration (solo → couple)
      allow update: if isSignedIn()
                    && (resource.data.coupleId == request.auth.uid
                        || isEventPartner(resource.data.coupleId));

      allow delete: if false;
    }

    // Default deny on everything else (Firestore built-in behavior).
  }
}
